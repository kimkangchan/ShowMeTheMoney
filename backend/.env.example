# DB 설정
DB_URL=jdbc:mysql://localhost:3306/showmethemoney?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=root
DB_PASSWORD=your_db_password

# JWT 설정 (SECRET은 32자 이상 랜덤 문자열 권장: openssl rand -hex 32)
JWT_SECRET=change-this-to-a-random-256bit-secret-key-before-use
JWT_EXPIRATION=86400

# CORS 허용 Origin 설정
# 로컬: 프론트엔드 개발 서버 주소 (포트 주의)
# 운영: 실제 서비스 도메인 (여러 개는 쉼표로 구분, 공백 없이)
# 예) CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000
